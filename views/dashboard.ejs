<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Dashboard | Glimora.pk</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Glimora Global Styles -->
    <link href="/css/style.css" rel="stylesheet">

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>

<%- include("partials/navbar") %>

<div class="container py-5">

<div class="dashboard-header d-flex justify-content-between align-items-center flex-wrap">

<div>

<h2>Admin Dashboard</h2>

<p class="mb-0 text-muted">
Manage your store, products and orders.
</p>

</div>

<div class="top-actions mt-3 mt-md-0">

<a href="/add-product" class="btn btn-primary me-2">
<i class="bi bi-plus-circle"></i>
Add Product
</a>

<a href="/orders" class="btn btn-success me-2">
<i class="bi bi-bag-check"></i>
View Orders
</a>

<a href="/" class="btn btn-outline-dark">
<i class="bi bi-house"></i>
Visit Store
</a>

</div>

</div>

<!-- Statistics -->

<div class="row g-4 mb-5">

<div class="col-md-3">

<div class="card stat-card shadow-sm">

<div class="card-body text-center">

<div class="stat-icon text-primary">
<i class="bi bi-box-seam"></i>
</div>

<h6 class="mt-3">Products</h6>

<h2 class="fw-bold text-primary">
<%= totalProducts %>
</h2>

</div>

</div>

</div>

<div class="col-md-3">

<div class="card stat-card shadow-sm">

<div class="card-body text-center">

<div class="stat-icon text-success">
<i class="bi bi-bag-check"></i>
</div>

<h6 class="mt-3">Orders</h6>

<h2 class="fw-bold text-success">
<%= totalOrders %>
</h2>

</div>

</div>

</div>

<div class="col-md-3">

<div class="card stat-card shadow-sm">

<div class="card-body text-center">

<div class="stat-icon text-danger">
<i class="bi bi-people"></i>
</div>

<h6 class="mt-3">Users</h6>

<h2 class="fw-bold text-danger">
<%= totalUsers %>
</h2>

</div>

</div>

</div>

<div class="col-md-3">

<div class="card stat-card shadow-sm">

<div class="card-body text-center">

<div class="stat-icon text-warning">
<i class="bi bi-cash-stack"></i>
</div>

<h6 class="mt-3">Revenue</h6>

<h2 class="fw-bold text-warning">

Rs. <%= revenue %>

</h2>

</div>

</div>

</div>

</div>

<!-- Products Table -->

<div class="table-card shadow">

<div class="table-responsive">

<table class="table table-hover align-middle mb-0">

<thead class="table-light">

<tr>

<th>Image</th>

<th>Name</th>

<th>Price</th>

<th>Stock</th>

<th class="text-center">Actions</th>

</tr>

</thead>

<tbody>

<% products.forEach(product=>{ %>

<tr>

<td>

<img src="/<%= product.images[0] %>">

</td>

<td>

<strong><%= product.name %></strong>

</td>

<td>

Rs. <%= product.price %>

</td>

<td>

<% if(product.stock==0){ %>

<span class="badge bg-danger">

Out of Stock

</span>

<% }else if(product.stock<=5){ %>

<span class="badge bg-warning text-dark">

Low Stock (<%= product.stock %>)

</span>

<% }else{ %>

<span class="badge bg-success">

<%= product.stock %> Available

</span>

<% } %>

</td>

<td class="text-center">

<a href="/api/products/<%= product._id %>/edit"
class="btn btn-warning btn-sm action-btn">

<i class="bi bi-pencil-square"></i>

Edit

</a>

<form
action="/api/products/<%= product._id %>"
method="POST"
class="d-inline">
<input type="hidden" name="_method" value="DELETE">

<button
class="btn btn-danger btn-sm action-btn"
onclick="return confirm('Delete this product?')">

<i class="bi bi-trash"></i>

Delete

</button>

</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</div>

</body>

</html>