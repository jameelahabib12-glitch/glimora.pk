<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product | Glimora.pk</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Glimora Global Styles -->
    <link href="/css/style.css" rel="stylesheet">
</head>

<body>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow p-4">

                <h2 class="text-center mb-4">
                    Edit Product
                </h2>

                <form action="/api/products/<%= product._id %>" method="POST">
                    <input type="hidden" name="_method" value="PUT">

                    <!-- Product Name -->
                    <div class="mb-3">
                        <label class="form-label">Product Name</label>

                        <input
                            type="text"
                            name="name"
                            class="form-control"
                            value="<%= product.name %>"
                            required
                        >
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label class="form-label">Description</label>

                        <textarea
                            name="description"
                            class="form-control"
                            rows="4"
                            required><%= product.description %></textarea>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">

                            <label class="form-label">Price</label>

                            <input
                                type="number"
                                name="price"
                                class="form-control"
                                value="<%= product.price %>"
                                required>

                        </div>

                        <div class="col-md-6 mb-3">

                            <label class="form-label">Stock</label>

                            <input
                                type="number"
                                name="stock"
                                class="form-control"
                                value="<%= product.stock %>"
                                required>

                        </div>

                    </div>

                    <!-- Images -->

                    <h5 class="mt-3 mb-3">Product Images</h5>

                    <div class="mb-3">

                        <label class="form-label">Image 1</label>

                        <input
                            type="text"
                            name="image1"
                            class="form-control"
                            value="<%= product.images[0] || '' %>">

                    </div>

                    <div class="mb-3">

                        <label class="form-label">Image 2</label>

                        <input
                            type="text"
                            name="image2"
                            class="form-control"
                            value="<%= product.images[1] || '' %>">

                    </div>

                    <div class="mb-3">

                        <label class="form-label">Image 3</label>

                        <input
                            type="text"
                            name="image3"
                            class="form-control"
                            value="<%= product.images[2] || '' %>">

                    </div>

                    <div class="mb-3">

                        <label class="form-label">Image 4</label>

                        <input
                            type="text"
                            name="image4"
                            class="form-control"
                            value="<%= product.images[3] || '' %>">

                    </div>

                    <!-- Preview -->

                    <% if(product.images && product.images.length > 0){ %>

                    <div class="mb-4">

                        <label class="form-label">Current Images</label>

                        <div class="d-flex flex-wrap">

                            <% product.images.forEach(image => { %>

                                <img
                                    src="/<%= image %>"
                                    class="preview-img">

                            <% }) %>

                        </div>

                    </div>

                    <% } %>

                    <div class="d-grid">

                        <button
                            class="btn btn-custom btn-lg"
                            type="submit">

                            Update Product

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

</body>
</html>