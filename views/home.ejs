<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Glimora.pk | Handmade Bag Charms</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Glimora Global Styles -->
    <link href="/css/style.css" rel="stylesheet">


    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Google Font -->
</head>
<body>

<!-- Navbar -->

<%- include("partials/navbar") %>

<!-- Hero -->

<section class="hero">

<div class="container">

<div class="row align-items-center">

<div class="col-lg-6">

<h1>
Make Every Bag<br>
Uniquely Yours
</h1>

<p class="my-4 fs-5">
Handmade bag charms, keychains, and customizable accessories crafted with love.
</p>

<a href="/products" class="blue-btn text-decoration-none">
Shop Now
</a>

</div>

</div>

</div>

</section>

<!-- Featured -->

<section class="py-5">

<div class="container">

<h2 class="text-center section-title">
Featured Charms
</h2>

<div class="row g-4">

<% if(products.length === 0){ %>

    <div class="col-12 text-center">
        <h4>No products available.</h4>
    </div>

<% } %>

<% products.forEach(product => { %>

<div class="col-md-3">

    <div class="card shadow-sm product-card h-100">

        <img src="/<%= product.images[0] %>" class="card-img-top">

        <div class="card-body text-center d-flex flex-column">

            <h5><%= product.name %></h5>

            <p class="text-muted small">
                <%= product.description.substring(0, 50) %>...
            </p>

            <p class="fw-bold text-primary">
                Rs. <%= product.price %>
            </p>

            <div class="mt-auto">

                <a href="/product-details/<%= product._id %>"
                   class="btn btn-outline-primary w-100 mb-2">
                    View Details
                </a>

                <% if(product.stock > 0){ %>

<form action="/cart/add/<%= product._id %>" method="POST">

<button class="btn btn-dark w-100">

Add to Cart

</button>

</form>

<% } else { %>

<button class="btn btn-secondary w-100" disabled>

Out of Stock

</button>

<% } %>

            </div>

        </div>

    </div>

</div>

<% }) %>

</div>

</div>

</section>

<!-- Promo -->

<section class="promo">

<div class="container">

<div class="row align-items-center">

<div class="col-lg-6">

<h2 class="display-5 fw-bold">
Summer Collection
</h2>

<p>
Celebrate the season with handcrafted charms and accessories designed to brighten every bag.
</p>

<button class="blue-btn">
Explore Now
</button>

</div>

</div>

</div>

</section>

<!-- Why Us -->

<section class="py-5">

<div class="container">

<h2 class="text-center section-title">
Why Shop With Us?
</h2>

<div class="row g-4">

<div class="col-md-4">

<div class="feature-box text-center">

<h4>🎀 Handmade</h4>

<p>Every piece is carefully crafted with attention to detail.</p>

</div>

</div>

<div class="col-md-4">

<div class="feature-box text-center">

<h4>✨ Customizable</h4>

<p>Create charms with initials, colors, and styles you love.</p>

</div>

</div>

<div class="col-md-4">

<div class="feature-box text-center">

<h4>💝 Premium Quality</h4>

<p>Made using durable materials and premium accessories.</p>

</div>

</div>

</div>

</div>

</section>

<!-- Footer -->

<footer>

<div class="container">

<div class="row">

<div class="col-md-4">

<h3>Glimora.pk</h3>

<p>
Handmade charms that add personality and elegance to every bag.
</p>

</div>

<div class="col-md-4">

<h5>Quick Links</h5>

<p><a href="#">Home</a></p>
<p><a href="#">Shop</a></p>
<p><a href="#">About</a></p>
<p><a href="#">Contact</a></p>

</div>

<div class="col-md-4">

<h5>Follow Us</h5>

<i class="bi bi-instagram fs-3 me-2"></i>
<i class="bi bi-facebook fs-3 me-2"></i>
<i class="bi bi-pinterest fs-3 me-2"></i>
<i class="bi bi-tiktok fs-3"></i>

</div>

</div>

<hr>

<p class="text-center mb-0">
© 2026 Glimora.pk. All Rights Reserved.
</p>

</div>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>