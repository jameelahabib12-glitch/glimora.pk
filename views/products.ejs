<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Products | Glimora.pk</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background:#f8fbff;
            font-family:'Poppins',sans-serif;
        }

        .navbar{
            background:#fff;
        }

        .navbar-brand{
            font-size:2rem;
            font-weight:bold;
        }

        .page-header{
            background:#d2e2f1;
            padding:60px 0;
            text-align:center;
        }

        .product-card{
            border:none;
            border-radius:15px;
            transition:.3s;
            overflow:hidden;
        }

        .product-card:hover{
            transform:translateY(-6px);
        }

        .product-card img{
            height:250px;
            object-fit:cover;
        }

        .price{
            font-size:1.2rem;
            font-weight:600;
            color:#0d6efd;
        }

        .stock{
            font-size:.9rem;
        }

        footer{
            background:#222;
            color:#fff;
            padding:25px 0;
            margin-top:60px;
        }
    </style>
</head>

<body>

<%- include("partials/navbar") %>

<section class="page-header">
    <div class="container">
        <h1 class="fw-bold">Our Collection</h1>
        <p class="mb-0">
            Explore our handcrafted charms and accessories.
        </p>
    </div>
</section>

<div class="container mb-4">

    <form method="GET" action="/products" class="d-flex">

        <input
            type="text"
            name="search"
            class="form-control me-2"
            placeholder="Search products..."
            value="<%= searchQuery ? searchQuery : '' %>"
        >

        <button class="btn btn-primary">
            Search
        </button>

    </form>

</div>

<div class="container py-5">

    <div class="row g-4">

        <% if(products.length === 0){ %>

            <div class="col-12 text-center">
    <h4>No products found</h4>
    <p>Try a different search term</p>
</div>

        <% } %>

        <% products.forEach(product => { %>

        <div class="col-md-6 col-lg-4 col-xl-3">

            <div class="card shadow-sm product-card h-100">

                <img
                    src="/<%= product.images[0] %>"
                    class="card-img-top"
                    alt="<%= product.name %>"
                >

                <div class="card-body d-flex flex-column">

                    <h5 class="fw-bold">
                        <%= product.name %>
                    </h5>

                    <p class="text-muted small">
                        <%= product.description %>
                    </p>

                    <p class="price">
                        Rs. <%= product.price %>
                    </p>

                    <p class="stock">
                        Stock:
                        <span class="badge bg-success">
                            <%= product.stock %>
                        </span>
                    </p>

                    <div class="mt-auto d-grid gap-2">

    <a
        href="/product-details/<%= product._id %>"
        class="btn btn-outline-primary"
    >
        View Details
    </a>

    <% if(session.user && session.user.role === "admin"){ %>

        <a
            href="/api/products/edit/<%= product._id %>"
            class="btn btn-warning"
        >
            Edit Product
        </a>

        <form
            action="/api/products/delete/<%= product._id %>"
            method="POST"
            onsubmit="return confirm('Are you sure you want to delete this product?')"
        >

            <button type="submit" class="btn btn-danger w-100">
                Delete Product
            </button>

        </form>

    <% } else { %>

        <% if(product.stock > 0){ %>

<form action="/cart/add/<%= product._id %>" method="POST">

    <button
        type="submit"
        class="btn btn-dark w-100">

        Add to Cart

    </button>

</form>

<% } else { %>

<button
class="btn btn-secondary w-100"
disabled>

Out of Stock

</button>

<% } %>

    <% } %>

</div>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>

<footer>
    <div class="container text-center">
        © 2026 Glimora.pk | Handmade Bag Charms
    </div>
</footer>

</body>
</html>