<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product | Glimora.pk</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background:#f8fbff;
            font-family:'Poppins',sans-serif;
        }

        .card{
            border:none;
            border-radius:20px;
        }

        .btn-custom{
            background:#acd0f2;
            color:#fff;
            border:none;
        }

        .btn-custom:hover{
            background:#8bb9e6;
            color:#fff;
        }
    </style>
</head>

<body>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow p-4">

                <h2 class="text-center mb-4">
                    Add New Product
                </h2>

                <form action="/api/products/add" method="POST">

                    <div class="mb-3">
                        <label class="form-label">Product Name</label>
                        <input
                            type="text"
                            name="name"
                            class="form-control"
                            required
                        >
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea
                            name="description"
                            class="form-control"
                            rows="4"
                            required
                        ></textarea>
                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Price</label>
                            <input
                                type="number"
                                name="price"
                                class="form-control"
                                required
                            >
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Stock</label>
                            <input
                                type="number"
                                name="stock"
                                class="form-control"
                                required
                            >
                        </div>

                    </div>

                    <div class="mb-3">
                        <label class="form-label">Image 1</label>
<input
type="text"
name="image1"
class="form-control"
placeholder="images/product1.jpg">

<label class="form-label mt-3">Image 2</label>
<input
type="text"
name="image2"
class="form-control"
placeholder="images/product2.jpg">

<label class="form-label mt-3">Image 3</label>
<input
type="text"
name="image3"
class="form-control"
placeholder="images/product3.jpg">

<label class="form-label mt-3">Image 4</label>
<input
type="text"
name="image4"
class="form-control"
placeholder="images/product4.jpg">
                    </div>

                    <div class="d-grid">

                        <button
                            class="btn btn-custom btn-lg"
                            type="submit"
                        >
                            Add Product
                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

</body>
</html>