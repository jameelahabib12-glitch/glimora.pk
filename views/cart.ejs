<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cart | Glimora.pk</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Glimora Global Styles -->
    <link href="/css/style.css" rel="stylesheet">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>

<%- include("partials/navbar") %>

<div class="container py-5">

<h2 class="mb-4">Your Cart</h2>

<table class="table align-middle">
<thead>
<tr>
<th>Product</th>
<th>Price</th>
<th>Qty</th>
<th>Total</th>
<th>Action</th>
</tr>
</thead>

<tbody>

<% if (cartItems.length === 0) { %>

<tr>
    <td colspan="5" class="text-center">
        <h5>Your cart is empty.</h5>
    </td>
</tr>

<% } else { %>

    <% let grandTotal = 0; %>

    <% cartItems.forEach(item => { %>

        <% if(item.product){ %>

            <% const total = item.product.price * item.quantity; %>
            <% grandTotal += total; %>
            <% const productImage = item.product.images && item.product.images.length > 0 ? item.product.images[0] : "images/no-image.png"; %>

            <tr>

                <td>
                    <img src="/<%= productImage %>" alt="<%= item.product.name %>" class="me-2">
                    <%= item.product.name %>
                </td>

                <td>
                    Rs. <%= item.product.price %>
                </td>

                <td>
                    <%= item.quantity %>
                </td>

                <td>
                    Rs. <%= total %>
                </td>

                <td>
                    <a href="/cart/remove/<%= item._id %>"
                       class="btn btn-danger btn-sm">
                        Remove
                    </a>
                </td>

            </tr>

        <% } %>

    <% }) %>

<% } %>

</tbody>
</table>

<div class="text-end">

<% if (cartItems.length > 0) { %>

    <% let grandTotal = 0; %>
    <% cartItems.forEach(item => { %>
        <% if (item.product) { %>
            <% grandTotal += item.product.price * item.quantity; %>
        <% } %>
    <% }) %>

    <h4>Total: Rs. <%= grandTotal %></h4>

    <a href="/checkout" class="btn btn-custom px-4 py-2 mt-2">
        Checkout
    </a>

<% } %>

</div>

</div>

</body>
</html>